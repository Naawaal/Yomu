{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .github/hooks/scripts/session-context.ps1",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .github/hooks/scripts/flutter-quality.ps1",
        "timeout": 45
      }
    ]
  }
}

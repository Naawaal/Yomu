{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/session-context.sh",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/flutter-quality.sh",
        "timeout": 45
      }
    ]
  }
}
